PORT=5000

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=cloudshaw_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Option 1: MongoDB Atlas (recommended - free tier)
# 1. Go to https://www.mongodb.com/atlas/database → Create free cluster
# 2. Go to Database Access → Add user with password
# 3. Go to Network Access → Allow IP: 0.0.0.0/0
# 4. Click "Connect" → "Compass" → Copy the connection string
# 5. Replace <username>, <password>, and <dbname> below:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cloudshaw?retryWrites=true&w=majority

# Option 2: Local MongoDB (requires MongoDB installed)
MONGODB_URI=mongodb://localhost:27017/cloudshaw
